# =============================================================================
# Ansilume — development environment example
#
# Copy this file to .env and adjust as needed.
# For production deployments, use .env.prod.example instead.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Framework environment. Controls error verbosity, debug toolbar, and caching.
# Values: dev | prod | test
APP_ENV=dev

# Yii2 environment. Should match APP_ENV.
# Values: dev | prod
YII_ENV=dev

# Enable Yii2 debug mode (shows stack traces, debug toolbar). Never set in prod.
# Values: 0 | 1
YII_DEBUG=1

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

# Host port that nginx binds to. Access Ansilume at http://localhost:NGINX_PORT
# Default: 8080
NGINX_PORT=8080

# External URL used in notification emails, API curl examples, and trigger URLs.
# Set this when running behind a reverse proxy or on a custom domain.
# Default: http://localhost:8080
# APP_URL=https://ansilume.example.com

# -----------------------------------------------------------------------------
# Database (MariaDB / MySQL)
# -----------------------------------------------------------------------------

# Root password for the MariaDB container. Not used by the application itself.
DB_ROOT_PASSWORD=rootsecret

# Application database name.
# Default: ansilume
DB_NAME=ansilume

# Application database user.
# Default: ansilume
DB_USER=ansilume

# Application database password.
DB_PASSWORD=secret

# Database host. Use the Docker Compose service name when using a container.
# Default: db
DB_HOST=db

# Database port.
# Default: 3306
DB_PORT=3306

# Test database name (used by PHPUnit integration tests only).
# Default: ansilume_test
DB_TEST_NAME=ansilume_test

# -----------------------------------------------------------------------------
# Redis (cache, sessions, queue)
# -----------------------------------------------------------------------------

# Redis host. Use the Docker Compose service name when using a container.
# Default: redis
REDIS_HOST=redis

# Redis port.
# Default: 6379
REDIS_PORT=6379

# Redis database index. Use different indices to separate environments on a
# shared Redis instance.
# Default: 0
REDIS_DB=0

# -----------------------------------------------------------------------------
# Security — CHANGE BEFORE ANY REAL DEPLOYMENT
# -----------------------------------------------------------------------------

# Key used to sign browser cookies. Must be at least 32 characters.
# Generate with: openssl rand -hex 32
COOKIE_VALIDATION_KEY=change-me-to-a-random-string-at-least-32-chars

# Key used to encrypt stored credentials (AES-256-CBC). Must be at least 32
# characters. Changing this after credentials are stored will break decryption.
# Generate with: openssl rand -hex 32
APP_SECRET_KEY=change-me-to-another-random-string-32chars

# Shared secret that allows runners to self-register against any runner group.
# Leave empty to disable self-registration (runners must be created manually).
# Generate with: openssl rand -hex 24
RUNNER_BOOTSTRAP_SECRET=change-me-to-a-random-string

# Send session cookies only over HTTPS. Set to true behind a TLS-terminating
# proxy or directly on HTTPS. Must stay false for plain-http local dev
# or the browser will drop the cookie.
# Default: false
SESSION_COOKIE_SECURE=false

# Idle timeout for user sessions in seconds. The session is destroyed after
# this many seconds with no request.
# Default: 43200 (12 hours)
SESSION_TIMEOUT=43200

# -----------------------------------------------------------------------------
# Runner execution
# -----------------------------------------------------------------------------

# How ansible-playbook is executed on the queue worker.
# local  — runs directly on the worker host (default)
# docker — wraps each job in a fresh Docker container (better isolation)
# Default: local
RUNNER_MODE=local

# Docker image used when RUNNER_MODE=docker.
# Must have ansible-playbook available on PATH.
# Default: cytopia/ansible:latest
RUNNER_DOCKER_IMAGE=cytopia/ansible:latest

# -----------------------------------------------------------------------------
# File paths (advanced — usually not needed with Docker)
# -----------------------------------------------------------------------------

# Working directory for job execution scratch space.
# Default: /tmp/ansilume/jobs
#JOB_WORKSPACE_PATH=/tmp/ansilume/jobs

# Directory where job log files are written.
# Default: /var/www/runtime/job-logs
#JOB_LOG_PATH=/var/www/runtime/job-logs

# -----------------------------------------------------------------------------
# Artifacts
# -----------------------------------------------------------------------------

# Maximum size in bytes for a single uploaded job artifact file.
# Default: 10485760 (10 MB)
ARTIFACT_MAX_FILE_SIZE=10485760

# Maximum total artifact bytes collected per job run.
# Prevents a runaway playbook from exhausting disk in a single run.
# 0 = unlimited.
# Default: 52428800 (50 MB)
ARTIFACT_MAX_BYTES_PER_JOB=52428800

# Global cap on total artifact bytes across all jobs. 0 = unlimited.
# Default: 0
ARTIFACT_MAX_TOTAL_BYTES=0

# Number of days to retain job artifacts. 0 = keep forever.
# Expired artifacts are purged by: php yii artifact/cleanup
# Default: 0
ARTIFACT_RETENTION_DAYS=0

# Retention by job count — keep only the N most recent jobs that have
# artifacts. 0 = unlimited. Combined with ARTIFACT_RETENTION_DAYS as OR:
# an artifact is removed if EITHER rule matches. Example: with N=100 and
# 500 jobs currently storing artifacts, the next maintenance sweep will
# delete artifacts from the 400 oldest jobs.
ARTIFACT_MAX_JOBS_WITH_ARTIFACTS=0

# -----------------------------------------------------------------------------
# Maintenance
# -----------------------------------------------------------------------------

# Seconds between automatic artifact-cleanup sweeps. The schedule-runner
# container runs `php yii maintenance/run` every minute; this value is the
# cooldown between actual cleanup invocations. 0 disables the scheduled sweep
# (operators must run `php yii artifact/cleanup` manually).
# Default: 86400 (daily)
MAINTENANCE_ARTIFACT_CLEANUP_INTERVAL=86400

# Seconds without runner progress before a RUNNING job is considered stuck.
# A job is reclaimed (marked failed) when its assigned runner is also offline.
# Reclaim sweep runs via: php yii job/reclaim-stale  (cron every minute)
# Default: 600 (10 minutes) — tune up for jobs with long silent task gaps.
JOB_PROGRESS_TIMEOUT=600

# What to do with a stuck job once detected by the reclaim sweep.
#   fail    — mark the job FAILED and stop (default; safest, most visible).
#   requeue — push the job back to QUEUED so a healthy runner picks it up,
#             up to job.max_attempts times. Falls back to fail at the limit.
# Use "requeue" when transient runner crashes are common and idempotent
# playbooks make a clean re-run safe; stick with "fail" otherwise.
JOB_RECLAIM_MODE=fail

# Seconds a job may sit in QUEUED before queue-starvation detection kicks in.
# Only failed if NO live Yii-queue worker exists AND the target runner group
# has zero online runners — i.e. nothing on the system can ever pick it up.
# Default: 1800 (30 minutes). Comfortably above worst-case worker restart.
JOB_QUEUE_TIMEOUT=1800

# -----------------------------------------------------------------------------
# Mail / SMTP
# -----------------------------------------------------------------------------

# SMTP server hostname. Leave empty to disable outgoing mail (logs to file).
# Dev default: MailHog — catches all mail without sending it.
SMTP_HOST=mailhog

# SMTP port.
# Common values: 25 (plain), 465 (SMTPS), 587 (STARTTLS)
# Default: 1025 (MailHog)
SMTP_PORT=1025

# TLS/SSL mode. Leave empty for no encryption.
# Values: tls | ssl | (empty)
SMTP_ENCRYPTION=

# SMTP credentials. Leave empty if your server allows unauthenticated relay.
SMTP_USER=
SMTP_PASSWORD=

# From address shown as the notification sender.
SENDER_EMAIL=noreply@ansilume.local

# Default admin e-mail address (used in system notifications if no other
# recipient is configured).
ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# LDAP / Active Directory integration (optional)
# -----------------------------------------------------------------------------
# When enabled, users bound against the directory can log in alongside local
# users. Local accounts keep working; LDAP users are auto-provisioned on first
# successful bind and cannot change their password through Ansilume.
# See docs/ldap.md for full setup guidance.

# Master switch. Must be true to enable any LDAP code path.
# Values: true | false
# Default: false
LDAP_ENABLED=false

# Directory server hostname or IP. Leave empty while LDAP_ENABLED=false.
#LDAP_HOST=dc01.example.com

# Directory port.
# 389 for plain / STARTTLS, 636 for LDAPS (implicit TLS).
# Default: 389
#LDAP_PORT=389

# Transport encryption.
# none     — plaintext 389 (dev only; never production)
# starttls — upgrade 389 connection to TLS after handshake (recommended)
# ldaps    — implicit TLS on port 636
# Default: none
#LDAP_ENCRYPTION=starttls

# Verify the directory server certificate. Disable only for self-signed
# test environments; production must verify peer certs.
# Default: true
#LDAP_VERIFY_PEER=true

# Network timeout for the initial bind in seconds.
# Default: 5
#LDAP_TIMEOUT=5

# Search base for user and group lookups.
# Example (AD):       DC=example,DC=com
# Example (OpenLDAP): dc=example,dc=com
#LDAP_BASE_DN=DC=example,DC=com

# Service-account used to search the directory before binding as the user.
# Create a read-only account in the directory and store its credentials here.
#LDAP_BIND_DN=CN=ansilume-svc,OU=Service Accounts,DC=example,DC=com
#LDAP_BIND_PASSWORD=

# LDAP filter used to locate a user by the username submitted in the login
# form. %s is replaced with the escaped username. Typical values:
#   AD:       (&(objectClass=user)(sAMAccountName=%s))
#   OpenLDAP: (&(objectClass=inetOrgPerson)(uid=%s))
# Default: (&(objectClass=user)(sAMAccountName=%s))
#LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName=%s))

# Attribute names. Defaults match Active Directory — override for OpenLDAP.
# Default: sAMAccountName
#LDAP_ATTR_USERNAME=sAMAccountName
# Default: mail
#LDAP_ATTR_EMAIL=mail
# Default: displayName
#LDAP_ATTR_DISPLAY_NAME=displayName
# Stable immutable identifier — use objectGUID for AD, entryUUID for OpenLDAP.
# This value is persisted to user.ldap_uid and survives username renames.
# Default: objectGUID
#LDAP_ATTR_UID=objectGUID

# Group lookup — applied to figure out which groups a user belongs to.
# %s is replaced with the user DN. Typical values:
#   AD:       (&(objectClass=group)(member=%s))
#   OpenLDAP: (&(objectClass=posixGroup)(member=%s))
# Default: (&(objectClass=group)(member=%s))
#LDAP_GROUP_FILTER=(&(objectClass=group)(member=%s))
# Default: cn
#LDAP_GROUP_NAME_ATTR=cn

# Map directory group names to Ansilume roles (admin | operator | viewer, or
# any custom role). JSON object — keys are group names (as returned by
# LDAP_GROUP_NAME_ATTR), values are Ansilume role names. Leave empty for no
# automatic role assignment.
# Example: {"AnsilumeAdmins":"admin","AnsilumeOps":"operator"}
#LDAP_ROLE_MAPPING={}

# Fallback role assigned when no group mapping matches. Empty = no role
# auto-assigned (user logs in but has no permissions until granted manually).
# Default: (empty)
#LDAP_DEFAULT_ROLE=viewer

# Auto-create a local user record on first successful LDAP bind.
# When false, only users already created in the UI with auth_source=ldap
# can log in via LDAP.
# Default: true
#LDAP_AUTO_PROVISION=true

# -----------------------------------------------------------------------------
# Audit log — SIEM integration (optional)
# -----------------------------------------------------------------------------

# Forward audit events to syslog. Compatible with Promtail/Loki, Splunk syslog
# input, rsyslog, and most SIEM collectors.
# Values: true | false
# Default: false
AUDIT_SYSLOG_ENABLED=false

# syslog ident string prepended to each audit message.
# Default: ansilume
AUDIT_SYSLOG_IDENT=ansilume

# syslog facility used for audit messages.
# Common values: LOG_LOCAL0 … LOG_LOCAL7, LOG_DAEMON, LOG_USER
# Default: LOG_LOCAL0
AUDIT_SYSLOG_FACILITY=LOG_LOCAL0

# -----------------------------------------------------------------------------
# Dev tools (not used in prod)
# -----------------------------------------------------------------------------

# Host port for the Adminer database browser (http://localhost:ADMINER_PORT)
ADMINER_PORT=8081

# Host port for MailHog web UI (http://localhost:MAILHOG_PORT)
MAILHOG_PORT=8025
