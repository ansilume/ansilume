# Application
APP_ENV=dev
YII_ENV=dev
YII_DEBUG=1

# Nginx
NGINX_PORT=8080

# Database
DB_ROOT_PASSWORD=rootsecret
DB_NAME=ansilume
DB_USER=ansilume
DB_PASSWORD=secret
DB_PORT=3306
DB_HOST=db
DB_TEST_NAME=ansilume_test

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Runner isolation (optional)
# Set to "docker" to run ansible-playbook inside a container per job.
# Leave empty or "local" for direct execution (default).
RUNNER_MODE=local
# Docker image to use when RUNNER_MODE=docker.
RUNNER_DOCKER_IMAGE=cytopia/ansible:latest

# Mail / SMTP
# Dev default: MailHog (catches all mail, UI at http://localhost:8025)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_ENCRYPTION=
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=admin@example.com
SENDER_EMAIL=noreply@ansilume.local
# For production, replace the above with real SMTP credentials.
MAILHOG_PORT=8025

# Artifacts
# Maximum single artifact file size in bytes (default 10 MB)
ARTIFACT_MAX_FILE_SIZE=10485760

# Audit log — SIEM integration (syslog)
# Enable to forward audit events to syslog (works with Promtail/Loki, Splunk syslog input, rsyslog)
AUDIT_SYSLOG_ENABLED=false
AUDIT_SYSLOG_IDENT=ansilume
AUDIT_SYSLOG_FACILITY=LOG_LOCAL0

# Dev tools
ADMINER_PORT=8081

# Runner self-registration
# Runners with no pre-configured token can register automatically using this
# shared secret. Set a non-empty value to enable. Leave empty to disable.
RUNNER_BOOTSTRAP_SECRET=change-me-to-a-random-string

# Security — CHANGE BOTH before any real deployment
COOKIE_VALIDATION_KEY=change-me-to-a-random-string-at-least-32-chars
# Used to encrypt credential secrets (AES-256-CBC). Min 32 chars, keep secret.
APP_SECRET_KEY=change-me-to-another-random-string-32chars
