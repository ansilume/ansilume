#!/usr/bin/env bash
# ============================================================================
# Ansilume Stack Diagnostics
#
# Collects system, container, and application state to help debug startup
# problems. All secrets, passwords, and tokens are redacted automatically.
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/ansilume/ansilume/main/bin/diagnose | bash
#   # — or —
#   ./bin/diagnose
#   # — or, to save output —
#   ./bin/diagnose > ansilume-diag.txt 2>&1
#
# The output is safe to share with developers — no credentials are included.
# ============================================================================

set -euo pipefail

# ── Helpers ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

section() { printf "\n${CYAN}═══ %s ═══${NC}\n\n" "$1"; }
ok()      { printf "  ${GREEN}✓${NC} %s\n" "$1"; }
warn()    { printf "  ${YELLOW}⚠${NC} %s\n" "$1"; }
fail()    { printf "  ${RED}✗${NC} %s\n" "$1"; }
info()    { printf "  %s\n" "$1"; }

# Redact values that look like secrets from a key=value stream.
# Matches: PASSWORD, SECRET, KEY, TOKEN (case-insensitive).
redact() {
    sed -E 's/(PASSWORD|SECRET|KEY|TOKEN)([=:][[:space:]]*)([^[:space:]]+)/\1\2***REDACTED***/gi'
}

# ── Preamble ─────────────────────────────────────────────────────────────────

printf "${BOLD}Ansilume Stack Diagnostics${NC}\n"
printf "Generated: %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
printf "Hostname:  %s\n" "$(hostname 2>/dev/null || echo unknown)"

# ── 0. Ansilume version ─────────────────────────────────────────────────────

app_container_early=$(docker compose ps -q app 2>/dev/null | head -1 || true)
if [ -n "$app_container_early" ]; then
    app_version=$(docker exec "$app_container_early" cat /var/www/VERSION 2>/dev/null | tr -d '[:space:]' || echo "unknown")
    printf "Version:   %s\n" "$app_version"
fi

# ── 1. Host environment ─────────────────────────────────────────────────────

section "Host Environment"

info "OS:     $(uname -srm)"
if [ -f /etc/os-release ]; then
    info "Distro: $(. /etc/os-release && echo "${PRETTY_NAME:-unknown}")"
fi
info "Kernel: $(uname -r)"
info "Uptime: $(uptime -p 2>/dev/null || uptime)"

# Memory
if command -v free >/dev/null 2>&1; then
    total_mb=$(free -m | awk '/^Mem:/ {print $2}')
    avail_mb=$(free -m | awk '/^Mem:/ {print $7}')
    info "Memory: ${avail_mb}MB available / ${total_mb}MB total"
    if [ "$avail_mb" -lt 256 ]; then
        fail "Very low available memory (${avail_mb}MB) — containers may OOM"
    fi
fi

# Disk
if command -v df >/dev/null 2>&1; then
    disk_avail=$(df -h . 2>/dev/null | awk 'NR==2 {print $4}')
    disk_use=$(df -h . 2>/dev/null | awk 'NR==2 {print $5}')
    info "Disk:   ${disk_avail} available (${disk_use} used)"
fi

# ── 2. Docker ────────────────────────────────────────────────────────────────

section "Docker"

if ! command -v docker >/dev/null 2>&1; then
    fail "docker command not found"
    exit 1
fi

docker_version=$(docker version --format '{{.Server.Version}}' 2>/dev/null || echo "unknown")
info "Docker version: ${docker_version}"

if docker compose version >/dev/null 2>&1; then
    compose_version=$(docker compose version --short 2>/dev/null || echo "unknown")
    ok "Docker Compose: ${compose_version}"
else
    fail "docker compose not available"
fi

# ── 3. Configuration (.env) ──────────────────────────────────────────────────

section "Configuration (.env)"

if [ -f .env ]; then
    ok ".env file exists"

    # Check for CHANGE-ME defaults (skip comment lines)
    changeme_count=$(grep -v '^\s*#' .env 2>/dev/null | grep -c 'CHANGE-ME' || true)
    if [ "$changeme_count" -gt 0 ]; then
        fail "${changeme_count} variable(s) still set to CHANGE-ME"
        grep -v '^\s*#' .env | grep 'CHANGE-ME' | sed 's/=.*/=CHANGE-ME/' | while read -r line; do
            info "  → ${line}"
        done
    else
        ok "No CHANGE-ME defaults remaining"
    fi

    # Check required variables exist (not their values)
    for var in DB_PASSWORD DB_HOST COOKIE_VALIDATION_KEY APP_SECRET_KEY RUNNER_BOOTSTRAP_SECRET; do
        if grep -q "^${var}=" .env 2>/dev/null; then
            val=$(grep "^${var}=" .env | head -1 | cut -d= -f2-)
            if [ -z "$val" ] || [ "$val" = "CHANGE-ME" ]; then
                fail "${var} is empty or default"
            else
                ok "${var} is set"
            fi
        else
            fail "${var} is missing from .env"
        fi
    done

    # Show non-secret config values
    info ""
    info "Non-secret configuration:"
    grep -E '^(APP_ENV|YII_ENV|YII_DEBUG|NGINX_PORT|DB_NAME|DB_USER|DB_HOST|REDIS_HOST|REDIS_PORT|REDIS_DB|RUNNER_MODE|SMTP_HOST|SMTP_PORT)=' .env 2>/dev/null | while read -r line; do
        info "  ${line}"
    done
else
    fail ".env file not found"
    info "Create it with: cp .env.prod.example .env"
fi

# ── 4. Docker Compose file ───────────────────────────────────────────────────

section "Docker Compose File"

compose_file=""
for f in docker-compose.yml docker-compose.yaml docker-compose.prebuilt.yml; do
    if [ -f "$f" ]; then
        compose_file="$f"
        break
    fi
done

if [ -n "$compose_file" ]; then
    ok "Found: ${compose_file}"
    services=$(docker compose config --services 2>/dev/null | sort)
    info "Services defined: $(echo "$services" | tr '\n' ' ')"
else
    fail "No docker-compose file found"
fi

# ── 5. Container status ─────────────────────────────────────────────────────

section "Container Status"

# Use a format that shows the key info
docker compose ps --format 'table {{.Name}}\t{{.Status}}\t{{.Health}}' 2>/dev/null || \
    docker compose ps 2>/dev/null || \
    warn "Could not list containers"

echo ""

# Detailed health for each container
for container in $(docker compose ps -q 2>/dev/null); do
    name=$(docker inspect --format '{{.Name}}' "$container" 2>/dev/null | sed 's|^/||')
    state=$(docker inspect --format '{{.State.Status}}' "$container" 2>/dev/null)
    health=$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}no-healthcheck{{end}}' "$container" 2>/dev/null)
    restarts=$(docker inspect --format '{{.RestartCount}}' "$container" 2>/dev/null)

    status_icon="✓"
    color="$GREEN"
    if [ "$state" != "running" ]; then
        status_icon="✗"; color="$RED"
    elif [ "$health" = "unhealthy" ]; then
        status_icon="⚠"; color="$YELLOW"
    elif [ "$health" = "starting" ]; then
        status_icon="…"; color="$YELLOW"
    fi

    printf "  ${color}${status_icon}${NC} %-30s state=%-10s health=%-12s restarts=%s\n" \
        "$name" "$state" "$health" "$restarts"

    # Show last health check log if unhealthy
    if [ "$health" = "unhealthy" ]; then
        last_output=$(docker inspect --format '{{range .State.Health.Log}}{{.Output}}{{end}}' "$container" 2>/dev/null | tail -1 || true)
        if [ -n "$last_output" ]; then
            info "    Last healthcheck output: $(echo "$last_output" | head -3 | redact)"
        fi
    fi
done

# ── 6. Image versions ───────────────────────────────────────────────────────

section "Image Versions"

for container in $(docker compose ps -q 2>/dev/null); do
    name=$(docker inspect --format '{{.Name}}' "$container" 2>/dev/null | sed 's|^/||')
    image=$(docker inspect --format '{{.Config.Image}}' "$container" 2>/dev/null)
    created=$(docker inspect --format '{{.Created}}' "$container" 2>/dev/null | cut -d. -f1)
    info "$(printf '%-30s %s  (created: %s)' "$name" "$image" "$created")"
done

# ── 7. Network connectivity ─────────────────────────────────────────────────

section "Network Connectivity"

# Check if containers can reach each other
app_container=$(docker compose ps -q app 2>/dev/null | head -1 || true)
nginx_container=$(docker compose ps -q nginx 2>/dev/null | head -1 || true)

if [ -n "$app_container" ]; then
    # Read DB and Redis host from .env (fall back to container defaults)
    db_host=$(grep -v '^\s*#' .env 2>/dev/null | grep '^DB_HOST=' | head -1 | cut -d= -f2-)
    db_host=${db_host:-db}
    redis_host=$(grep -v '^\s*#' .env 2>/dev/null | grep '^REDIS_HOST=' | head -1 | cut -d= -f2-)
    redis_host=${redis_host:-redis}
    redis_port=$(grep -v '^\s*#' .env 2>/dev/null | grep '^REDIS_PORT=' | head -1 | cut -d= -f2-)
    redis_port=${redis_port:-6379}

    # App → DB
    db_err=$(docker exec "$app_container" php -r "try { new PDO('mysql:host=${db_host}', 'x', 'x'); echo 'ok'; } catch(Exception \$e) { echo \$e->getMessage(); }" 2>/dev/null | head -1)
    if echo "$db_err" | grep -qi "ok\|access denied"; then
        ok "app → db (${db_host}): reachable"
    elif echo "$db_err" | grep -qi "refused\|timed out\|no such host\|getaddrinfo"; then
        fail "app → db (${db_host}): connection failed — ${db_err}"
    else
        warn "app → db (${db_host}): uncertain — ${db_err}"
    fi

    # App → Redis
    if docker exec "$app_container" php -r "try { \$r = new Redis(); \$r->connect('${redis_host}', ${redis_port}, 2); echo 'ok'; } catch(Exception \$e) { echo \$e->getMessage(); }" 2>/dev/null | grep -q "ok"; then
        ok "app → redis (${redis_host}:${redis_port}): reachable"
    else
        warn "app → redis (${redis_host}:${redis_port}): may not be reachable"
    fi

    # Health check from inside app
    info ""
    info "App health check:"
    health_output=$(docker exec "$app_container" php /var/www/yii health/check 2>&1 || true)
    if [ -n "$health_output" ]; then
        echo "$health_output" | redact | while read -r line; do
            info "  ${line}"
        done
    fi
fi

if [ -n "$nginx_container" ]; then
    # Nginx → App (FastCGI)
    if docker exec "$nginx_container" sh -c "nc -zw2 app 9000 2>/dev/null" 2>/dev/null; then
        ok "nginx → app:9000 (FastCGI): reachable"
    else
        fail "nginx → app:9000 (FastCGI): not reachable"
    fi

    # Nginx self-test
    http_status=$(docker exec "$nginx_container" sh -c "wget -qSO /dev/null http://127.0.0.1/ 2>&1 | head -1" 2>/dev/null || true)
    if [ -n "$http_status" ]; then
        info "nginx self-test: ${http_status}"
    else
        warn "nginx self-test: no response"
    fi
fi

# ── 8. Container logs (last 30 lines each) ───────────────────────────────────

section "Recent Logs (last 30 lines per container)"

for svc in db redis app nginx queue-worker schedule-runner runner-1; do
    container_id=$(docker compose ps -q "$svc" 2>/dev/null | head -1 || true)
    if [ -z "$container_id" ]; then
        warn "${svc}: not running"
        continue
    fi

    printf "\n  ${BOLD}── %s ──${NC}\n" "$svc"
    log_output=$(docker logs --tail 30 "$container_id" 2>&1 || true)
    if [ -n "$log_output" ]; then
        echo "$log_output" | redact | while read -r line; do
            printf "    %s\n" "$line"
        done
    else
        info "(no log output)"
    fi
done

# ── 9. Migration status ─────────────────────────────────────────────────────

section "Migration Status"

if [ -n "$app_container" ]; then
    migration_output=$(docker exec "$app_container" php /var/www/yii migrate/history 10 2>&1 || true)
    if echo "$migration_output" | grep -qi "error\|exception\|fail"; then
        fail "Migration check failed"
        echo "$migration_output" | redact | head -10 | while read -r line; do
            info "  ${line}"
        done
    else
        ok "Last 10 applied migrations:"
        echo "$migration_output" | tail -12 | while read -r line; do
            info "  ${line}"
        done
    fi
else
    warn "App container not running — cannot check migrations"
fi

# ── 10. Runner — project sync capability ────────────────────────────────────

section "Runner — Project Sync"

runner_svcs=$(docker compose config --services 2>/dev/null | grep '^runner' || true)

if [ -z "$runner_svcs" ]; then
    warn "No runner services defined in compose file"
else
    for runner_svc in $runner_svcs; do
        runner_cid=$(docker compose ps -q "$runner_svc" 2>/dev/null | head -1 || true)
        if [ -z "$runner_cid" ]; then
            warn "${runner_svc}: not running"
            continue
        fi

        # Check git is installed in the runner container.
        if docker exec "$runner_cid" git --version >/dev/null 2>&1; then
            git_ver=$(docker exec "$runner_cid" git --version 2>/dev/null || echo "unknown")
            ok "${runner_svc}: git available (${git_ver})"
        else
            fail "${runner_svc}: git not found — runner cannot sync git projects (upgrade to latest runner image)"
        fi

        # Check how many projects have been synced locally.
        proj_count=$(docker exec "$runner_cid" sh -c \
            'ls /var/www/runtime/projects/ 2>/dev/null | wc -l' 2>/dev/null | tr -d '[:space:]' || echo "0")
        if [ "${proj_count:-0}" -gt 0 ]; then
            ok "${runner_svc}: ${proj_count} project(s) synced in runtime/projects/"
        else
            info "${runner_svc}: no projects synced yet (first git-backed job will trigger a clone)"
        fi
    done
fi

# ── 10b. Project sync status ────────────────────────────────────────────────

if [ -n "$app_container" ]; then
    section "Project Sync Status"

    sync_output=$(docker exec "$app_container" php -r "
        require '/var/www/vendor/autoload.php';
        require '/var/www/config/bootstrap.php';
        \$app = new yii\console\Application(require '/var/www/config/console.php');
        \$projects = app\models\Project::find()->all();
        foreach (\$projects as \$p) {
            printf(\"%d|%s|%s|%s|%s\n\",
                \$p->id,
                \$p->name,
                \$p->scm_type,
                \$p->status,
                \$p->last_sync_error ?? ''
            );
        }
    " 2>/dev/null || true)

    if [ -n "$sync_output" ]; then
        has_issues=false
        while IFS='|' read -r pid pname pscm pstatus perror; do
            case "$pstatus" in
                synced)
                    ok "Project #${pid} '${pname}' (${pscm}): synced"
                    ;;
                syncing)
                    warn "Project #${pid} '${pname}' (${pscm}): stuck in syncing state"
                    has_issues=true
                    ;;
                error)
                    fail "Project #${pid} '${pname}' (${pscm}): sync error — ${perror}"
                    has_issues=true
                    ;;
                new)
                    info "Project #${pid} '${pname}' (${pscm}): not yet synced"
                    ;;
                *)
                    info "Project #${pid} '${pname}' (${pscm}): status=${pstatus}"
                    ;;
            esac
        done <<< "$sync_output"

        if [ "$has_issues" = true ]; then
            info ""
            info "To re-sync a stuck project, use the web UI: Projects → select project → Sync"
        fi
    else
        info "No projects found or could not query project status"
    fi
fi

# ── 10c. Application integrity ─────────────────────────────────────────────

section "Application Integrity"

if [ -n "$app_container" ]; then
    # Vendor autoload
    if docker exec "$app_container" test -f /var/www/vendor/autoload.php 2>/dev/null; then
        if docker exec "$app_container" php -r "require '/var/www/vendor/autoload.php'; echo 'ok';" 2>/dev/null | grep -q "ok"; then
            ok "vendor/autoload.php: present and loadable"
        else
            fail "vendor/autoload.php: exists but cannot be loaded (corrupted)"
            info "  Fix: docker compose exec app composer install"
        fi
    else
        fail "vendor/autoload.php: missing"
        info "  Fix: docker compose exec app composer install"
    fi

    # Runtime directories
    dirs_ok=true
    for dir in /var/www/runtime /var/www/runtime/projects /var/www/runtime/artifacts /var/www/runtime/logs /var/www/web/assets; do
        if ! docker exec "$app_container" test -w "$dir" 2>/dev/null; then
            fail "Directory not writable: ${dir}"
            dirs_ok=false
        fi
    done
    if [ "$dirs_ok" = true ]; then
        ok "Runtime directories: all writable"
    fi

    # RBAC core roles
    rbac_output=$(docker exec "$app_container" php -r "
        require '/var/www/vendor/autoload.php';
        require '/var/www/config/bootstrap.php';
        \$app = new yii\console\Application(require '/var/www/config/console.php');
        \$auth = \$app->authManager;
        foreach (['admin', 'operator', 'viewer'] as \$r) {
            echo (\$auth->getRole(\$r) !== null ? 'ok' : 'missing') . '|' . \$r . PHP_EOL;
        }
    " 2>/dev/null || true)

    if [ -n "$rbac_output" ]; then
        rbac_ok=true
        while IFS='|' read -r rstatus rname; do
            if [ "$rstatus" != "ok" ]; then
                fail "RBAC role missing: ${rname}"
                rbac_ok=false
            fi
        done <<< "$rbac_output"
        if [ "$rbac_ok" = true ]; then
            ok "RBAC roles: admin, operator, viewer present"
        else
            info "  RBAC roles are created by migrations. Run: docker compose exec app php yii migrate"
        fi
    else
        warn "Could not check RBAC roles"
    fi

    # Admin user exists
    admin_output=$(docker exec "$app_container" php -r "
        require '/var/www/vendor/autoload.php';
        require '/var/www/config/bootstrap.php';
        \$app = new yii\console\Application(require '/var/www/config/console.php');
        \$total = (int)app\models\User::find()->count();
        \$admins = (int)app\models\User::find()->where(['is_superadmin' => true])->count();
        echo \$total . '|' . \$admins;
    " 2>/dev/null || true)

    if [ -n "$admin_output" ]; then
        user_total=$(echo "$admin_output" | cut -d'|' -f1)
        admin_count=$(echo "$admin_output" | cut -d'|' -f2)
        if [ "${user_total:-0}" -eq 0 ]; then
            fail "No users in database — login is impossible"
            info "  Fix: docker compose exec app php yii setup/admin admin admin@example.com yourpassword"
        elif [ "${admin_count:-0}" -eq 0 ]; then
            warn "Users exist (${user_total}) but no superadmin — may not be able to manage the system"
        else
            ok "Users: ${user_total} total, ${admin_count} superadmin(s)"
        fi
    else
        warn "Could not check user accounts"
    fi
else
    warn "App container not running — cannot check application integrity"
fi

# ── 10d. Login page accessibility ──────────────────────────────────────────

if [ -n "$nginx_container" ]; then
    login_status=$(docker exec "$nginx_container" sh -c \
        "wget -qSO /dev/null http://127.0.0.1/login 2>&1 | head -1" 2>/dev/null || true)
    if echo "$login_status" | grep -q "200"; then
        ok "Login page: accessible (HTTP 200)"
    elif [ -n "$login_status" ]; then
        warn "Login page: unexpected response — ${login_status}"
    else
        warn "Login page: no response from nginx"
    fi
fi

# ── 11. Port conflicts ──────────────────────────────────────────────────────

section "Port Conflicts"

nginx_port=$(grep '^NGINX_PORT=' .env 2>/dev/null | cut -d= -f2- || echo "8080")
nginx_port=${nginx_port:-8080}

if command -v ss >/dev/null 2>&1; then
    listeners=$(ss -tlnp 2>/dev/null | grep ":${nginx_port} " | grep -v docker || true)
    if [ -n "$listeners" ]; then
        fail "Port ${nginx_port} is also used by another process:"
        echo "$listeners" | while read -r line; do
            info "  ${line}"
        done
    else
        ok "Port ${nginx_port} has no conflicts outside Docker"
    fi
elif command -v netstat >/dev/null 2>&1; then
    listeners=$(netstat -tlnp 2>/dev/null | grep ":${nginx_port} " | grep -v docker || true)
    if [ -n "$listeners" ]; then
        fail "Port ${nginx_port} is also used by another process"
    else
        ok "Port ${nginx_port} has no conflicts outside Docker"
    fi
fi

# ── 12. Docker network ──────────────────────────────────────────────────────

section "Docker Networks"

docker network ls --filter name=ansilume --format 'table {{.Name}}\t{{.Driver}}\t{{.Scope}}' 2>/dev/null || \
    warn "Could not list Docker networks"

# ── 13. Disk usage ──────────────────────────────────────────────────────────

section "Docker Disk Usage"

docker system df 2>/dev/null || warn "Could not get Docker disk usage"

# ── Summary ──────────────────────────────────────────────────────────────────

section "Diagnosis Summary"

all_ok=true

# Build list of expected services from compose config
expected_services=$(docker compose config --services 2>/dev/null || echo "app nginx redis")

for svc in $expected_services; do
    container_id=$(docker compose ps -q "$svc" 2>/dev/null | head -1 || true)
    if [ -z "$container_id" ]; then
        # Distinguish critical from optional
        case "$svc" in
            app|nginx)  fail "${svc}: NOT RUNNING (critical)"; all_ok=false ;;
            runner-*)   warn "${svc}: not running (may be blocked by dependency)" ;;
            *)          warn "${svc}: not running" ;;
        esac
        continue
    fi
    state=$(docker inspect --format '{{.State.Status}}' "$container_id" 2>/dev/null)
    health=$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$container_id" 2>/dev/null)

    if [ "$state" != "running" ]; then
        fail "${svc}: stopped (state=${state})"
        all_ok=false
    elif [ "$health" = "unhealthy" ]; then
        warn "${svc}: running but unhealthy"
        all_ok=false
    elif [ "$health" = "starting" ]; then
        warn "${svc}: still starting up"
    else
        ok "${svc}: healthy"
    fi
done

# Application integrity in summary
if [ -n "$app_container" ]; then
    # Re-check admin user for summary
    summary_admin=$(docker exec "$app_container" php -r "
        require '/var/www/vendor/autoload.php';
        require '/var/www/config/bootstrap.php';
        \$app = new yii\console\Application(require '/var/www/config/console.php');
        echo (int)app\models\User::find()->where(['is_superadmin' => true])->count();
    " 2>/dev/null || echo "0")
    if [ "${summary_admin:-0}" -eq 0 ]; then
        fail "admin-user: no superadmin exists"
        all_ok=false
    else
        ok "admin-user: ${summary_admin} superadmin(s)"
    fi

    # Re-check vendor for summary
    if ! docker exec "$app_container" php -r "require '/var/www/vendor/autoload.php'; echo 'ok';" 2>/dev/null | grep -q "ok"; then
        fail "vendor: autoload broken"
        all_ok=false
    else
        ok "vendor: intact"
    fi
fi

echo ""

# Known issue detection
nginx_id=$(docker compose ps -q nginx 2>/dev/null | head -1 || true)
runner_id=$(docker compose ps -q runner-1 2>/dev/null | head -1 || true)
if [ -n "$nginx_id" ] && [ -z "$runner_id" ]; then
    nginx_health=$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$nginx_id" 2>/dev/null)
    if [ "$nginx_health" = "unhealthy" ]; then
        echo ""
        printf "  ${YELLOW}${BOLD}Likely cause: Nginx healthcheck deadlock${NC}\n"
        info "  Nginx is unhealthy → runner-1 cannot start (depends_on: service_healthy)"
        info "  → runner never registers → /health reports degraded → nginx stays unhealthy"
        info ""
        info "  Workaround: restart the stack so Nginx's start_period gives the runner time:"
        info "    docker compose down && docker compose up -d"
        info ""
        info "  Permanent fix: update to the latest version which has a relaxed healthcheck."
    fi
fi

if [ "$all_ok" = true ]; then
    printf "${GREEN}${BOLD}All services are healthy.${NC}\n"
else
    printf "${YELLOW}${BOLD}Issues detected. Share this output with developers:${NC}\n"
    printf "  ./bin/diagnose > ansilume-diag.txt 2>&1\n"
fi

printf "\n${CYAN}End of diagnostics.${NC}\n"
