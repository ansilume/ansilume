#!/usr/bin/env bash
# =============================================================================
# Ansilume Quickstart
#
# Interactive installer. Supports prebuilt images and building from source.
#
# Usage (one-liner):
#   curl -fsSL https://raw.githubusercontent.com/ansilume/ansilume/main/bin/quickstart | bash
#
# Non-interactive with all defaults (admin/admin):
#   curl -fsSL https://raw.githubusercontent.com/ansilume/ansilume/main/bin/quickstart | bash -s -- --defaults
#
# Verbose mode (debug output):
#   ./bin/quickstart -v
#   curl -fsSL ... | bash -s -- --defaults -v
#
# Extra-verbose (includes full docker output):
#   ./bin/quickstart -vv
#
# Or run locally:
#   ./bin/quickstart [--defaults] [-v|-vv] [--help]
# =============================================================================

set -euo pipefail

# ── Parse arguments ─────────────────────────────────────────────────────────

DEFAULTS=0
VERBOSE=0
UNINSTALL=0
for arg in "$@"; do
    case "$arg" in
        --defaults) DEFAULTS=1 ;;
        --uninstall) UNINSTALL=1 ;;
        -vv) VERBOSE=2 ;;
        -v|--verbose) [ "$VERBOSE" -lt 1 ] && VERBOSE=1 ;;
        -h|--help)
            cat <<'HELP'
Ansilume Quickstart — interactive installer

Usage:
  ./bin/quickstart [OPTIONS]
  curl -fsSL https://raw.githubusercontent.com/ansilume/ansilume/main/bin/quickstart | bash
  curl -fsSL ... | bash -s -- [OPTIONS]

Options:
  --defaults    Non-interactive mode, use all defaults (admin/admin)
  --uninstall   Remove all Ansilume containers, images, and volumes
  -v, --verbose Show debug output at each step
  -vv           Extra-verbose: debug output + full docker command output
  -h, --help    Show this help and exit
HELP
            exit 0
            ;;
    esac
done

# ── Colours ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

ok()      { printf "  ${GREEN}✓${NC} %s\n" "$1"; }
warn()    { printf "  ${YELLOW}⚠${NC} %s\n" "$1"; }
fail()    { printf "  ${RED}✗${NC} %s\n" "$1"; }
info()    { printf "  %s\n" "$1"; }
debug()   { [ "$VERBOSE" -ge 1 ] && printf "  ${YELLOW}[debug]${NC} %s\n" "$1" || true; }
section() { printf "\n${CYAN}${BOLD}── %s ──${NC}\n\n" "$1"; }
die()     { printf "\n${RED}${BOLD}Error: %s${NC}\n\n" "$1" >&2; exit 1; }

# Read from /dev/tty so the script works when piped through curl | bash.
ask() {
    local prompt="$1"
    local default="${2:-}"
    local var_name="$3"
    local response

    if [ "$DEFAULTS" = "1" ] && [ -n "$default" ]; then
        eval "$var_name=\"\$default\""
        return
    fi

    if [ -n "$default" ]; then
        printf "  %s [%s]: " "$prompt" "$default" >/dev/tty
    else
        printf "  %s: " "$prompt" >/dev/tty
    fi

    read -r response </dev/tty
    if [ -z "$response" ] && [ -n "$default" ]; then
        response="$default"
    fi
    eval "$var_name=\"\$response\""
}

ask_secret() {
    local prompt="$1"
    local var_name="$2"
    local default="${3:-}"
    local response

    if [ "$DEFAULTS" = "1" ] && [ -n "$default" ]; then
        eval "$var_name=\"\$default\""
        return
    fi

    printf "  %s: " "$prompt" >/dev/tty
    read -rs response </dev/tty
    printf "\n" >/dev/tty
    eval "$var_name=\"\$response\""
}

gen_secret() {
    openssl rand -hex 32 2>/dev/null || { LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 64 || true; }
}

# ── Uninstall mode ──────────────────────────────────────────────────────────

if [ "$UNINSTALL" = "1" ]; then
    printf "\n${CYAN}${BOLD}"
    printf "  ╔═══════════════════════════════════════╗\n"
    printf "  ║       Ansilume Uninstall              ║\n"
    printf "  ╚═══════════════════════════════════════╝\n"
    printf "${NC}\n"

    UNINSTALL_DIR="$(pwd)"
    if [ -f "$UNINSTALL_DIR/docker-compose.yml" ] || [ -f "$UNINSTALL_DIR/docker-compose.prebuilt.yml" ]; then
        info "Uninstall directory: ${UNINSTALL_DIR}"
    else
        warn "No Ansilume installation found in ${UNINSTALL_DIR}"
        info "Run this command from the directory where Ansilume was installed."
        exit 1
    fi

    printf "\n"
    warn "This will remove all Ansilume containers, volumes, and images."
    warn "All data (database, projects, logs) will be permanently deleted."
    printf "\n"
    ask "Type 'yes' to confirm" "" CONFIRM_UNINSTALL

    if [ "$CONFIRM_UNINSTALL" != "yes" ]; then
        info "Uninstall cancelled."
        exit 0
    fi

    # Detect compose command
    if docker compose version >/dev/null 2>&1; then
        COMPOSE_CMD="docker compose"
    elif command -v docker-compose >/dev/null 2>&1; then
        COMPOSE_CMD="docker-compose"
    else
        fail "Neither 'docker compose' nor 'docker-compose' found."
        exit 1
    fi

    section "Removing containers and volumes"
    if [ -f "docker-compose.prebuilt.yml" ]; then
        $COMPOSE_CMD -f docker-compose.prebuilt.yml down -v --rmi all 2>/dev/null || true
    fi
    $COMPOSE_CMD down -v --rmi all 2>/dev/null || true
    ok "Containers, volumes, and images removed."

    section "Cleaning up files"
    # Remove generated config files but preserve user data awareness
    for f in .env docker-compose.prebuilt.yml; do
        if [ -f "$f" ]; then
            rm -f "$f"
            ok "Removed $f"
        fi
    done

    printf "\n${GREEN}${BOLD}Ansilume has been uninstalled.${NC}\n\n"
    info "To reinstall, run the quickstart again."
    printf "\n"
    exit 0
fi

# ── Header ───────────────────────────────────────────────────────────────────

# Fetch latest version tag (silent, falls back to "latest" if offline/error)
ANSILUME_VERSION=$(curl -fsSL https://api.github.com/repos/ansilume/ansilume/releases/latest 2>/dev/null \
    | grep -m1 '"tag_name"' | sed 's/.*"tag_name":[^"]*"\([^"]*\)".*/\1/' || true)
ANSILUME_VERSION="${ANSILUME_VERSION:-latest}"

BANNER_TEXT="Ansilume Quickstart Setup ${ANSILUME_VERSION}"
BANNER_LEN=${#BANNER_TEXT}
# Pad to minimum 37 chars (original box width), center content
INNER_WIDTH=$((BANNER_LEN + 4))
[ "$INNER_WIDTH" -lt 37 ] && INNER_WIDTH=37
PAD_TOTAL=$((INNER_WIDTH - BANNER_LEN))
PAD_LEFT=$((PAD_TOTAL / 2))
PAD_RIGHT=$((PAD_TOTAL - PAD_LEFT))
TOP_LINE=$(printf '═%.0s' $(seq 1 "$INNER_WIDTH"))
LEFT_PAD=$(printf ' %.0s' $(seq 1 "$PAD_LEFT"))
RIGHT_PAD=$(printf ' %.0s' $(seq 1 "$PAD_RIGHT"))

printf "\n${CYAN}${BOLD}"
printf "  ╔%s╗\n" "$TOP_LINE"
printf "  ║%s%s%s║\n" "$LEFT_PAD" "$BANNER_TEXT" "$RIGHT_PAD"
printf "  ╚%s╝\n" "$TOP_LINE"
printf "${NC}\n"
info "This script will configure and start Ansilume on this machine."
info "It only asks for the essentials — everything else uses sensible defaults."
printf "\n"

# ── 1. Prerequisites ─────────────────────────────────────────────────────────

section "Checking prerequisites"

if ! command -v docker >/dev/null 2>&1; then
    fail "Docker not found."
    info ""
    info "Install Docker: https://docs.docker.com/engine/install/"
    exit 1
fi
ok "Docker: $(docker --version | head -1)"

if ! docker info >/dev/null 2>&1; then
    fail "Cannot connect to the Docker daemon."
    info ""
    info "Either Docker is not running, or your user lacks permission."
    info "Try: sudo usermod -aG docker \$USER  (then log out and back in)"
    exit 1
fi
ok "Docker daemon reachable"

if docker compose version >/dev/null 2>&1; then
    ok "Docker Compose: $(docker compose version --short 2>/dev/null || echo 'v2')"
    COMPOSE_CMD="docker compose"
elif command -v docker-compose >/dev/null 2>&1; then
    ok "Docker Compose (standalone): $(docker-compose --version | head -1)"
    COMPOSE_CMD="docker-compose"
else
    fail "Docker Compose not found."
    info ""
    info "Install Docker Compose: https://docs.docker.com/compose/install/"
    exit 1
fi

if ! command -v openssl >/dev/null 2>&1; then
    warn "openssl not found — secrets will use /dev/urandom fallback"
fi

# ── 2. Deployment mode ───────────────────────────────────────────────────────

section "Deployment mode"

printf "  ${BOLD}[1]${NC} Prebuilt images  — pull from ghcr.io, no source code needed ${GREEN}(recommended)${NC}\n"
printf "  ${BOLD}[2]${NC} Build from source — clone the git repository and build locally\n"
printf "\n"
ask "Choose" "1" DEPLOY_MODE

if [ "$DEPLOY_MODE" = "2" ]; then
    if ! command -v git >/dev/null 2>&1; then
        die "git is required for source mode but was not found."
    fi
    ok "git: $(git --version)"
    SOURCE_MODE=true
else
    SOURCE_MODE=false
fi

# ── 3. Install directory ─────────────────────────────────────────────────────

section "Install location"

if [ "$SOURCE_MODE" = "true" ]; then
    info "The repository will be cloned into the chosen directory."
else
    info "Configuration files will be created in the chosen directory."
fi
printf "\n"
ask "Directory" "." INSTALL_DIR

# Resolve to absolute path.
INSTALL_DIR="$(mkdir -p "$INSTALL_DIR" && cd "$INSTALL_DIR" && pwd)"
ok "Install directory: ${INSTALL_DIR}"

# Handle existing installation.
INSTALL_MODE="fresh"
if [ -f "${INSTALL_DIR}/.env" ]; then
    if [ "$DEFAULTS" = "1" ]; then
        EXISTING_MODE=1
    else
        printf "\n"
        warn "Existing installation found in ${INSTALL_DIR}"
        printf "\n"
        printf "  ${BOLD}[1]${NC} Fresh install — removes all data and starts clean\n"
        printf "  ${BOLD}[2]${NC} Update        — pull latest images, keep data and config\n"
        printf "  ${BOLD}[3]${NC} Abort\n"
        printf "\n"
        ask "Choose" "3" EXISTING_MODE
    fi

    case "$EXISTING_MODE" in
        1)
            INSTALL_MODE="fresh"
            info "Stopping and removing existing containers and volumes..."

            # Determine compose file for teardown.
            if [ -f "docker-compose.prebuilt.yml" ] && [ "$SOURCE_MODE" = "true" ]; then
                TEARDOWN_ARGS="-f docker-compose.prebuilt.yml"
            else
                TEARDOWN_ARGS=""
            fi
            $COMPOSE_CMD $TEARDOWN_ARGS down -v < /dev/null 2>/dev/null || true
            ok "Existing installation removed"
            ;;
        2)
            INSTALL_MODE="update"
            ;;
        *)
            die "Aborted."
            ;;
    esac
fi

# ── Update path ─────────────────────────────────────────────────────────────
# Pull latest images and restart — skip all configuration steps.

if [ "$INSTALL_MODE" = "update" ]; then
    section "Updating"

    cd "$INSTALL_DIR"

    if [ "$SOURCE_MODE" = "true" ]; then
        info "Pulling latest source..."
        git pull --ff-only
        ok "Repository up to date"
        COMPOSE_FILE="docker-compose.prebuilt.yml"
    else
        COMPOSE_FILE="docker-compose.yml"
    fi

    if [ "$COMPOSE_FILE" != "docker-compose.yml" ]; then
        COMPOSE_ARGS="-f ${COMPOSE_FILE}"
    else
        COMPOSE_ARGS=""
    fi

    info "Pulling latest images and restarting..."
    if [ "$VERBOSE" -ge 2 ]; then
        $COMPOSE_CMD $COMPOSE_ARGS pull < /dev/null 2>&1 | while IFS= read -r line || [ -n "$line" ]; do
            info "  $line"
        done || true
        $COMPOSE_CMD $COMPOSE_ARGS up -d < /dev/null 2>&1 | while IFS= read -r line || [ -n "$line" ]; do
            info "  $line"
        done || true
    else
        $COMPOSE_CMD $COMPOSE_ARGS pull < /dev/null >/dev/null 2>&1 || true
        $COMPOSE_CMD $COMPOSE_ARGS up -d < /dev/null >/dev/null 2>&1 || true
    fi
    ok "Containers updated"

    info "Migrations will be applied automatically by the app container."
    printf "\n"
    ok "Update complete. Ansilume is restarting with the latest version."
    printf "\n"
    exit 0
fi

# ── 4. Database ──────────────────────────────────────────────────────────────

section "Database"

printf "  ${BOLD}[1]${NC} New MariaDB container — managed by Docker Compose ${GREEN}(recommended)${NC}\n"
printf "  ${BOLD}[2]${NC} External database     — connect to an existing MySQL/MariaDB server\n"
printf "\n"
ask "Choose" "1" DB_MODE

if [ "$DB_MODE" = "2" ]; then
    printf "\n"
    ask "Database host"          ""         DB_HOST
    ask "Database port"          "3306"     DB_PORT
    ask "Database name"          "ansilume" DB_NAME
    ask "Database user"          "ansilume" DB_USER
    ask_secret "Database password"          DB_PASSWORD
    DB_ROOT_PASSWORD=""
    ok "External database: ${DB_USER}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
else
    DB_HOST="db"
    DB_PORT="3306"
    DB_NAME="ansilume"
    DB_USER="ansilume"
    DB_PASSWORD="$(gen_secret | head -c 32)"
    DB_ROOT_PASSWORD="$(gen_secret | head -c 32)"
    ok "MariaDB container will be created (credentials auto-generated)"
fi

# ── 5. HTTP port ─────────────────────────────────────────────────────────────

section "Network"

ask "HTTP port" "8080" NGINX_PORT
ask "External URL (for notifications, API examples)" "http://localhost:${NGINX_PORT}" APP_URL
ok "Ansilume will be available at ${APP_URL}"

# ── 6. Admin account ─────────────────────────────────────────────────────────

section "Admin account"

info "This account will have full superadmin access."
printf "\n"
ask       "Admin username" "admin"             ADMIN_USER
ask       "Admin email"    "admin@example.com" ADMIN_EMAIL
while true; do
    ask_secret "Admin password (min. 5 characters)" ADMIN_PASSWORD "admin"
    if [ -z "$ADMIN_PASSWORD" ]; then
        fail "Password cannot be empty. Please enter at least 5 characters."
    elif [ "${#ADMIN_PASSWORD}" -lt 5 ]; then
        fail "Password too short (${#ADMIN_PASSWORD} chars). Please enter at least 5 characters."
    else
        break
    fi
done

# ── 7. Prepare files ─────────────────────────────────────────────────────────

section "Preparing files"

cd "$INSTALL_DIR"

if [ "$SOURCE_MODE" = "true" ]; then
    if [ -d ".git" ]; then
        info "Git repository already present — pulling latest changes."
        git pull --ff-only
        ok "Repository up to date"
    else
        info "Cloning ansilume/ansilume from GitHub..."
        git clone https://github.com/ansilume/ansilume.git .
        ok "Repository cloned"
    fi
    COMPOSE_FILE="docker-compose.prebuilt.yml"
else
    # Download the prebuilt compose file if not already present.
    COMPOSE_FILE="docker-compose.yml"
    if [ ! -f "$COMPOSE_FILE" ]; then
        info "Downloading docker-compose.yml..."
        curl -fsSL \
            "https://raw.githubusercontent.com/ansilume/ansilume/main/docker-compose.prebuilt.yml" \
            -o "$COMPOSE_FILE"
        ok "docker-compose.yml downloaded"
    else
        ok "docker-compose.yml already present"
    fi
fi

# ── 8. Generate .env ─────────────────────────────────────────────────────────

info "Generating .env..."

COOKIE_KEY="$(gen_secret)"
APP_SECRET="$(gen_secret)"
RUNNER_SECRET="$(gen_secret)"

cat > .env <<EOF
# Ansilume — generated by quickstart on $(date -u '+%Y-%m-%d %H:%M UTC')

APP_ENV=production
YII_ENV=prod
YII_DEBUG=0

NGINX_PORT=${NGINX_PORT}
APP_URL=${APP_URL}

DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_ROOT_PASSWORD=${DB_ROOT_PASSWORD}

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

COOKIE_VALIDATION_KEY=${COOKIE_KEY}
APP_SECRET_KEY=${APP_SECRET}
RUNNER_BOOTSTRAP_SECRET=${RUNNER_SECRET}
EOF

ok ".env written"
debug "COMPOSE_FILE=${COMPOSE_FILE}"

# ── 9. Start containers ───────────────────────────────────────────────────────

section "Starting containers"

if [ "$COMPOSE_FILE" != "docker-compose.yml" ]; then
    COMPOSE_ARGS="-f ${COMPOSE_FILE}"
else
    COMPOSE_ARGS=""
fi

# Remove leftover containers and volumes from a previous install.
# This prevents credential mismatches when the user deleted the directory
# but Docker volumes (with the old DB password) still exist.
debug "Checking for leftover containers..."
HAS_CONTAINERS=$($COMPOSE_CMD $COMPOSE_ARGS ps -q < /dev/null 2>/dev/null || true)
debug "HAS_CONTAINERS='${HAS_CONTAINERS}'"
debug "Checking for leftover volumes..."
ALL_VOLUMES=$(docker volume ls -q 2>/dev/null || true)
HAS_VOLUMES=""
if [ -n "$ALL_VOLUMES" ]; then
    HAS_VOLUMES=$(echo "$ALL_VOLUMES" | grep "^ansilume_" || true)
fi
debug "HAS_VOLUMES='${HAS_VOLUMES}'"
if [ -n "$HAS_CONTAINERS" ] || [ -n "$HAS_VOLUMES" ]; then
    info "Cleaning up leftover containers and volumes..."
    debug "Running compose down -v..."
    $COMPOSE_CMD $COMPOSE_ARGS down -v < /dev/null 2>/dev/null || true
    debug "compose down -v done"
    # Remove orphan volumes that match the project name.
    REMAINING_VOLUMES=$(docker volume ls -q 2>/dev/null || true)
    LEFTOVER_VOLS=""
    if [ -n "$REMAINING_VOLUMES" ]; then
        LEFTOVER_VOLS=$(echo "$REMAINING_VOLUMES" | grep "^ansilume_" || true)
    fi
    debug "LEFTOVER_VOLS='${LEFTOVER_VOLS}'"
    if [ -n "$LEFTOVER_VOLS" ]; then
        echo "$LEFTOVER_VOLS" | while read -r vol; do
            debug "Removing volume: $vol"
            docker volume rm "$vol" 2>/dev/null || true
        done
    fi
    ok "Cleanup complete"
else
    debug "No leftover containers or volumes found"
fi

debug "Running: $COMPOSE_CMD $COMPOSE_ARGS up -d --pull always"
info "Pulling images and starting services (this may take a moment)..."
if [ "$VERBOSE" -ge 2 ]; then
    $COMPOSE_CMD $COMPOSE_ARGS up -d --pull always < /dev/null 2>&1 | while IFS= read -r line || [ -n "$line" ]; do
        info "  $line"
    done || true
else
    $COMPOSE_CMD $COMPOSE_ARGS up -d --pull always < /dev/null >/dev/null 2>&1 || true
fi

ok "Containers started"

# ── 10. Wait for app to be healthy ───────────────────────────────────────────

section "Waiting for application"

info "Waiting for the app container to become healthy (up to 3 minutes)..."

debug "Getting app container ID..."
APP_CONTAINER=$($COMPOSE_CMD $COMPOSE_ARGS ps -q app < /dev/null 2>/dev/null | head -1 || true)
debug "APP_CONTAINER='${APP_CONTAINER}'"
TIMEOUT=180
ELAPSED=0

while [ $ELAPSED -lt $TIMEOUT ]; do
    HEALTH=$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$APP_CONTAINER" 2>/dev/null || echo "unknown")
    STATE=$(docker inspect --format '{{.State.Status}}' "$APP_CONTAINER" 2>/dev/null || echo "unknown")

    if [ "$HEALTH" = "healthy" ]; then
        ok "App container is healthy"
        break
    fi

    if [ "$STATE" != "running" ]; then
        fail "App container is not running (state: ${STATE})"
        info ""
        info "Check logs with: $COMPOSE_CMD logs app"
        exit 1
    fi

    debug "Health: ${HEALTH}, State: ${STATE} (${ELAPSED}s / ${TIMEOUT}s)"
    printf "  Waiting... (%ds / %ds)\r" "$ELAPSED" "$TIMEOUT"
    sleep 5
    ELAPSED=$((ELAPSED + 5))
done

if [ $ELAPSED -ge $TIMEOUT ]; then
    warn "Timed out waiting for healthy status — proceeding anyway"
fi

# ── 11. Create admin user ─────────────────────────────────────────────────────
# Migrations are handled by the app container's entrypoint automatically.

section "Setup"

debug "Creating admin user: $ADMIN_USER / $ADMIN_EMAIL"
info "Creating admin user..."
ADMIN_OUT=$($COMPOSE_CMD $COMPOSE_ARGS exec -T app \
    php yii setup/admin "$ADMIN_USER" "$ADMIN_EMAIL" "$ADMIN_PASSWORD" < /dev/null 2>&1) || true
debug "setup/admin output: ${ADMIN_OUT}"
case "$ADMIN_OUT" in
    *"already exists"*)
        ok "Admin user already exists — skipping"
        ;;
    *"created with ID"*)
        ok "Admin user created"
        ;;
    *)
        if [ -n "$ADMIN_OUT" ]; then
            echo "$ADMIN_OUT" | while IFS= read -r line || [ -n "$line" ]; do info "  $line"; done
        fi
        die "Admin user creation failed. Check the output above and re-run the quickstart."
        ;;
esac

# ── 12. Done ──────────────────────────────────────────────────────────────────

printf "\n${GREEN}${BOLD}"
printf "  ╔═══════════════════════════════════════╗\n"
printf "  ║         Ansilume is ready!            ║\n"
printf "  ╚═══════════════════════════════════════╝\n"
printf "${NC}\n"
ok "URL:      http://localhost:${NGINX_PORT}"
ok "Username: ${ADMIN_USER}"
ok "Email:    ${ADMIN_EMAIL}"
printf "\n"
info "Useful commands:"
info "  $COMPOSE_CMD logs -f          — follow container logs"
info "  $COMPOSE_CMD ps               — show container status"
info "  $COMPOSE_CMD down             — stop all containers"
info "  curl -fsSL https://raw.githubusercontent.com/ansilume/ansilume/main/bin/diagnose | bash"
info "                                — run diagnostics"
printf "\n"
info "Docs: https://github.com/ansilume/ansilume/tree/main/docs"
printf "\n"
