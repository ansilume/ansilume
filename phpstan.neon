parameters:
    level: 9
    bootstrapFiles:
        - phpstan-bootstrap.php
    paths:
        - controllers
        - models
        - services
        - commands
        - jobs
        - components
    excludePaths:
        - vendor
        - runtime
        - web/assets
    # Yii2's PHPDoc for findOne() etc. says non-nullable but callers must check for null.
    # Disable strict PHPDoc-based narrowing to avoid false "always false" warnings.
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # Yii2 queue extension adds $queue dynamically — not in the base Application class
        - '#Access to an undefined property yii\\(web|console)\\Application.*::\$queue#'

        # ── Yii2 framework type-union limitations ────────────────────────────
        # PHPStan sees \Yii::$app as yii\web\Application|yii\console\Application.
        # Web controllers always get web Request/Response/Application — these
        # are not real bugs, just framework type-system limitations.
        #
        # Strategy: suppress these globally; long-term fix is yii2-phpstan extension.

        # \Yii::$app->get('service') returns object — calling methods on it
        - '#Call to an undefined method object::#'

        # \Yii::$app->user / ->session only exist on web Application
        - '#Access to an undefined property yii\\(web|console)\\Application.*::\$(user|session)#'

        # \Yii::$app->request->post() / ->get() only exist on web Request
        - '#Call to an undefined method yii\\console\\Request\|yii\\web\\Request::(post|get)\(\)#'

        # \Yii::$app->request->bodyParams / ->queryParams / ->rawBody / ->headers / ->isPost
        - '#Access to an undefined property yii\\console\\Request\|yii\\web\\Request::\$(bodyParams|queryParams|rawBody|headers|isPost)#'

        # \Yii::$app->response->format / ->statusCode / ->data / ->headers / ->sendFile()
        - '#Access to an undefined property yii\\console\\Response\|yii\\web\\Response::\$(statusCode|format|data|headers)#'


        # Controller classes extend generic yii\web\Controller<T> / yii\console\Controller<T>
        - '#extends generic class yii\\(web|console)\\Controller but does not specify its types: T#'

        # ActiveQuery return types are generic in Yii2 but rarely specified
        - '#return type with generic class yii\\db\\ActiveQuery does not specify its types: T#'

        # ── Level 9: mixed → scalar cast safety ───────────────────────────────
        # PHPStan level 9 forbids (int)$mixed and (string)$mixed even though
        # these are safe, defensive casts. In Yii2 code, array<string, mixed>
        # values are always mixed; extracting them requires casting.
        # Suppress the cast error globally — the real bugs (offset access on
        # mixed, method calls on mixed) are NOT suppressed.
        - '#Cannot cast mixed to (int|float|string)#'

        # InventoryService::getCached() returns shape with mixed offsets from json_decode
        - '#should return array\{groups: array<string, mixed>, hosts: array<string, mixed>, error: string\|null\}\|null but returns#'
