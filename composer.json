{
    "name": "ansilume/ansilume",
    "description": "Web-based Ansible automation platform",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "yiisoft/yii2": "~2.0.49",
        "yiisoft/yii2-redis": "~2.0.0",
        "yiisoft/yii2-queue": "~2.3.0",
        "vlucas/phpdotenv": "^5.6",
        "dragonmantank/cron-expression": "^3.3",
        "spomky-labs/otphp": "^11.4",
        "bacon/bacon-qr-code": "^3.0"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0",
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpmd/phpmd": "^2.15",
        "systemsdk/phpcpd": "^7.0",
        "phpstan/phpstan-strict-rules": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "app\\tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "config": {
        "process-timeout": 1800,
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "oomphinc/composer-installers-extender": true,
            "composer/installers": true
        }
    },
    "extra": {
        "asset-installer-paths": {
            "npm-asset-dir": "vendor/npm-asset",
            "bower-asset-dir": "vendor/bower-asset"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
