# =============================================================================
# Ansilume — production environment example
#
# Copy this file to .env, fill in every value marked CHANGE-ME, and keep the
# file private (never commit it to version control).
#
# For development, use .env.example instead.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Framework environment. Must be prod in production.
APP_ENV=prod

# Yii2 environment. Must be prod in production.
YII_ENV=prod

# Debug mode. Must be 0 in production (exposes internals if enabled).
YII_DEBUG=0

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

# Host port that nginx binds to. Access Ansilume at http://localhost:NGINX_PORT
# Change this if port 8080 is already in use, or put a reverse proxy in front.
# Default: 8080
NGINX_PORT=8080

# External URL used in notification emails, API curl examples, and trigger URLs.
# Set this when running behind a reverse proxy or on a custom domain.
# Default: http://localhost:8080
# APP_URL=https://ansilume.example.com

# -----------------------------------------------------------------------------
# Database (MariaDB / MySQL)
# -----------------------------------------------------------------------------

# Root password for the MariaDB container. Not used by the application.
# CHANGE-ME — use a strong random password.
DB_ROOT_PASSWORD=CHANGE-ME

# Application database name. Rarely needs changing.
# Default: ansilume
DB_NAME=ansilume

# Application database user. Rarely needs changing.
# Default: ansilume
DB_USER=ansilume

# Application database password.
# CHANGE-ME — generate with: openssl rand -hex 24
DB_PASSWORD=CHANGE-ME

# Database host. Use the Docker Compose service name for a local container,
# or a hostname/IP for an external database server.
# Default: db
DB_HOST=db

# Database port. Only change if your server runs on a non-standard port.
# Default: 3306
DB_PORT=3306

# -----------------------------------------------------------------------------
# Redis (cache, sessions, queue)
# -----------------------------------------------------------------------------

# Redis host. Use the Docker Compose service name for a local container,
# or a hostname/IP for an external Redis instance.
# Default: redis
REDIS_HOST=redis

# Redis port.
# Default: 6379
REDIS_PORT=6379

# Redis database index. Increase if sharing a Redis instance with other
# applications to avoid key collisions.
# Default: 0
REDIS_DB=0

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Key used to sign browser cookies. Must be at least 32 characters.
# CHANGE-ME — generate with: openssl rand -hex 32
COOKIE_VALIDATION_KEY=CHANGE-ME

# Key used to encrypt stored credentials (AES-256-CBC). Must be at least 32
# characters. Do NOT change this after the application has stored credentials —
# doing so will permanently break decryption of all stored secrets.
# CHANGE-ME — generate with: openssl rand -hex 32
APP_SECRET_KEY=CHANGE-ME

# Shared secret that allows runners to self-register against any runner group.
# Leave empty to disable self-registration (runners must be pre-created in the
# UI and their tokens distributed manually).
# CHANGE-ME — generate with: openssl rand -hex 24
RUNNER_BOOTSTRAP_SECRET=CHANGE-ME

# Send session cookies only over HTTPS. Strongly recommended for production.
# Default: true
SESSION_COOKIE_SECURE=true

# Idle timeout for user sessions in seconds. Shorter = more secure but
# more frequent re-logins.
# Default: 43200 (12 hours)
SESSION_TIMEOUT=43200

# -----------------------------------------------------------------------------
# Runner execution
# -----------------------------------------------------------------------------

# How ansible-playbook is executed on the queue worker.
# local  — runs directly on the worker host (default, simpler setup)
# docker — wraps each job in a fresh Docker container (better isolation)
# Default: local
RUNNER_MODE=local

# Docker image used when RUNNER_MODE=docker.
# Must have ansible-playbook available on PATH.
# Default: cytopia/ansible:latest
#RUNNER_DOCKER_IMAGE=cytopia/ansible:latest

# -----------------------------------------------------------------------------
# File paths (advanced — usually not needed with Docker)
# -----------------------------------------------------------------------------

# Working directory for job execution scratch space.
# Default: /tmp/ansilume/jobs
#JOB_WORKSPACE_PATH=/tmp/ansilume/jobs

# Directory where job log files are written by the queue worker.
# Default: /var/www/runtime/job-logs
#JOB_LOG_PATH=/var/www/runtime/job-logs

# -----------------------------------------------------------------------------
# Artifacts
# -----------------------------------------------------------------------------

# Maximum size in bytes for a single uploaded job artifact file.
# Default: 10485760 (10 MB)
ARTIFACT_MAX_FILE_SIZE=10485760

# Maximum total artifact bytes collected per job run.
# Prevents a runaway playbook from exhausting disk in a single run.
# 0 = unlimited.
# Default: 52428800 (50 MB)
ARTIFACT_MAX_BYTES_PER_JOB=52428800

# Global cap on total artifact bytes across all jobs.
# When the cap is exceeded, new artifacts are skipped with a warning.
# Set to a sane percentage of your artifact volume size.
# 0 = unlimited.
# Default: 0
ARTIFACT_MAX_TOTAL_BYTES=0

# Number of days to retain job artifacts. 0 = keep forever.
# Expired artifacts are purged by: php yii artifact/cleanup
# Default: 0
ARTIFACT_RETENTION_DAYS=0

# -----------------------------------------------------------------------------
# Mail / SMTP
# -----------------------------------------------------------------------------

# SMTP server hostname. Leave empty to disable all outgoing mail.
# When set, job completion notifications and password reset emails are sent.
SMTP_HOST=

# SMTP port.
# Common values: 587 (STARTTLS, recommended), 465 (SMTPS), 25 (plain)
# Default: 587
SMTP_PORT=587

# TLS/SSL mode.
# Values: tls (STARTTLS on port 587) | ssl (implicit TLS on port 465) | (empty for no encryption)
SMTP_ENCRYPTION=tls

# SMTP credentials. Leave empty if your server allows unauthenticated relay.
SMTP_USER=
SMTP_PASSWORD=

# From address shown as the notification sender.
# Use a real deliverable address to avoid spam filtering.
SENDER_EMAIL=noreply@example.com

# Fallback admin e-mail address used in system notifications.
ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Audit log — SIEM integration (optional)
# -----------------------------------------------------------------------------

# Forward audit events to syslog. Compatible with Promtail/Loki, Splunk syslog
# input, rsyslog, and most SIEM collectors. All security-relevant actions
# (logins, credential changes, job launches, permission changes) are forwarded.
# Values: true | false
# Default: false
AUDIT_SYSLOG_ENABLED=false

# syslog ident string prepended to each audit message.
# Default: ansilume
AUDIT_SYSLOG_IDENT=ansilume

# syslog facility used for audit messages.
# Common values: LOG_LOCAL0 … LOG_LOCAL7, LOG_DAEMON, LOG_USER
# Default: LOG_LOCAL0
AUDIT_SYSLOG_FACILITY=LOG_LOCAL0
