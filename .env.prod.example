# Ansilume — production environment
# Copy this file to .env and fill in all values marked CHANGE-ME.

# Application
APP_ENV=prod
YII_ENV=prod
YII_DEBUG=0

# Nginx
NGINX_PORT=8080

# Database — CHANGE ALL THREE
DB_ROOT_PASSWORD=CHANGE-ME
DB_NAME=ansilume
DB_USER=ansilume
DB_PASSWORD=CHANGE-ME
DB_HOST=db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Security — CHANGE BOTH (min 32 chars each)
# Generate with: openssl rand -hex 32
COOKIE_VALIDATION_KEY=CHANGE-ME
APP_SECRET_KEY=CHANGE-ME

# Runner self-registration
# Generate with: openssl rand -hex 24
RUNNER_BOOTSTRAP_SECRET=CHANGE-ME

# Runner isolation (optional)
# Leave as "local" unless you want ansible-playbook isolated in its own container.
RUNNER_MODE=local

# Mail / SMTP (leave SMTP_HOST empty to disable outgoing mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=admin@example.com
SENDER_EMAIL=noreply@ansilume.local

# Artifacts
ARTIFACT_MAX_FILE_SIZE=10485760

# Audit log — SIEM integration (optional)
AUDIT_SYSLOG_ENABLED=false
AUDIT_SYSLOG_IDENT=ansilume
AUDIT_SYSLOG_FACILITY=LOG_LOCAL0
