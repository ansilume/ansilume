# =============================================================================
# Ansilume — production environment example
#
# Copy this file to .env, fill in every value marked CHANGE-ME, and keep the
# file private (never commit it to version control).
#
# For development, use .env.example instead.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Framework environment. Must be prod in production.
APP_ENV=prod

# Yii2 environment. Must be prod in production.
YII_ENV=prod

# Debug mode. Must be 0 in production (exposes internals if enabled).
YII_DEBUG=0

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

# Host port that nginx binds to. Access Ansilume at http://localhost:NGINX_PORT
# Change this if port 8080 is already in use, or put a reverse proxy in front.
# Default: 8080
NGINX_PORT=8080

# External URL used in notification emails, API curl examples, and trigger URLs.
# Set this when running behind a reverse proxy or on a custom domain.
# Default: http://localhost:8080
# APP_URL=https://ansilume.example.com

# -----------------------------------------------------------------------------
# Database (MariaDB / MySQL)
# -----------------------------------------------------------------------------

# Root password for the MariaDB container. Not used by the application.
# CHANGE-ME — use a strong random password.
DB_ROOT_PASSWORD=CHANGE-ME

# Application database name. Rarely needs changing.
# Default: ansilume
DB_NAME=ansilume

# Application database user. Rarely needs changing.
# Default: ansilume
DB_USER=ansilume

# Application database password.
# CHANGE-ME — generate with: openssl rand -hex 24
DB_PASSWORD=CHANGE-ME

# Database host. Use the Docker Compose service name for a local container,
# or a hostname/IP for an external database server.
# Default: db
DB_HOST=db

# Database port. Only change if your server runs on a non-standard port.
# Default: 3306
DB_PORT=3306

# -----------------------------------------------------------------------------
# Redis (cache, sessions, queue)
# -----------------------------------------------------------------------------

# Redis host. Use the Docker Compose service name for a local container,
# or a hostname/IP for an external Redis instance.
# Default: redis
REDIS_HOST=redis

# Redis port.
# Default: 6379
REDIS_PORT=6379

# Redis database index. Increase if sharing a Redis instance with other
# applications to avoid key collisions.
# Default: 0
REDIS_DB=0

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Key used to sign browser cookies. Must be at least 32 characters.
# CHANGE-ME — generate with: openssl rand -hex 32
COOKIE_VALIDATION_KEY=CHANGE-ME

# Key used to encrypt stored credentials (AES-256-CBC). Must be at least 32
# characters. Do NOT change this after the application has stored credentials —
# doing so will permanently break decryption of all stored secrets.
# CHANGE-ME — generate with: openssl rand -hex 32
APP_SECRET_KEY=CHANGE-ME

# Shared secret that allows runners to self-register against any runner group.
# Leave empty to disable self-registration (runners must be pre-created in the
# UI and their tokens distributed manually).
# CHANGE-ME — generate with: openssl rand -hex 24
RUNNER_BOOTSTRAP_SECRET=CHANGE-ME

# Send session cookies only over HTTPS. Strongly recommended for production.
# Default: true
SESSION_COOKIE_SECURE=true

# Idle timeout for user sessions in seconds. Shorter = more secure but
# more frequent re-logins.
# Default: 43200 (12 hours)
SESSION_TIMEOUT=43200

# -----------------------------------------------------------------------------
# Runner execution
# -----------------------------------------------------------------------------

# How ansible-playbook is executed on the queue worker.
# local  — runs directly on the worker host (default, simpler setup)
# docker — wraps each job in a fresh Docker container (better isolation)
# Default: local
RUNNER_MODE=local

# Docker image used when RUNNER_MODE=docker.
# Must have ansible-playbook available on PATH.
# Default: cytopia/ansible:latest
#RUNNER_DOCKER_IMAGE=cytopia/ansible:latest

# -----------------------------------------------------------------------------
# File paths (advanced — usually not needed with Docker)
# -----------------------------------------------------------------------------

# Working directory for job execution scratch space.
# Default: /tmp/ansilume/jobs
#JOB_WORKSPACE_PATH=/tmp/ansilume/jobs

# Directory where job log files are written by the queue worker.
# Default: /var/www/runtime/job-logs
#JOB_LOG_PATH=/var/www/runtime/job-logs

# -----------------------------------------------------------------------------
# Artifacts
# -----------------------------------------------------------------------------

# Maximum size in bytes for a single uploaded job artifact file.
# Default: 10485760 (10 MB)
ARTIFACT_MAX_FILE_SIZE=10485760

# Maximum total artifact bytes collected per job run.
# Prevents a runaway playbook from exhausting disk in a single run.
# 0 = unlimited.
# Default: 52428800 (50 MB)
ARTIFACT_MAX_BYTES_PER_JOB=52428800

# Global cap on total artifact bytes across all jobs.
# When the cap is exceeded, new artifacts are skipped with a warning.
# Set to a sane percentage of your artifact volume size.
# 0 = unlimited.
# Default: 0
ARTIFACT_MAX_TOTAL_BYTES=0

# Number of days to retain job artifacts. 0 = keep forever.
# Expired artifacts are purged by: php yii artifact/cleanup
# Default: 0
ARTIFACT_RETENTION_DAYS=0

# Retention by job count — keep only the N most recent jobs that have
# artifacts. 0 = unlimited. Combined with ARTIFACT_RETENTION_DAYS as OR:
# an artifact is removed if EITHER rule matches. Example: with N=100 and
# 500 jobs currently storing artifacts, the next maintenance sweep will
# delete artifacts from the 400 oldest jobs.
ARTIFACT_MAX_JOBS_WITH_ARTIFACTS=0

# -----------------------------------------------------------------------------
# Maintenance
# -----------------------------------------------------------------------------

# Seconds between automatic artifact-cleanup sweeps. The schedule-runner
# container runs `php yii maintenance/run` every minute; this value is the
# cooldown between actual cleanup invocations. 0 disables the scheduled sweep
# (operators must run `php yii artifact/cleanup` manually).
# Default: 86400 (daily)
MAINTENANCE_ARTIFACT_CLEANUP_INTERVAL=86400

# Seconds without runner progress before a RUNNING job is considered stuck.
# A job is reclaimed (marked failed) when its assigned runner is also offline.
# Reclaim sweep runs via: php yii job/reclaim-stale  (cron every minute)
# Default: 600 (10 minutes) — tune up for jobs with long silent task gaps.
JOB_PROGRESS_TIMEOUT=600

# What to do with a stuck job once detected by the reclaim sweep.
#   fail    — mark the job FAILED and stop (default; safest, most visible).
#   requeue — push the job back to QUEUED so a healthy runner picks it up,
#             up to job.max_attempts times. Falls back to fail at the limit.
# Use "requeue" when transient runner crashes are common and idempotent
# playbooks make a clean re-run safe; stick with "fail" otherwise.
JOB_RECLAIM_MODE=fail

# Seconds a job may sit in QUEUED before queue-starvation detection kicks in.
# Only failed if NO live Yii-queue worker exists AND the target runner group
# has zero online runners — i.e. nothing on the system can ever pick it up.
# Default: 1800 (30 minutes). Comfortably above worst-case worker restart.
JOB_QUEUE_TIMEOUT=1800

# -----------------------------------------------------------------------------
# Mail / SMTP
# -----------------------------------------------------------------------------

# SMTP server hostname. Leave empty to disable all outgoing mail.
# When set, job completion notifications and password reset emails are sent.
SMTP_HOST=

# SMTP port.
# Common values: 587 (STARTTLS, recommended), 465 (SMTPS), 25 (plain)
# Default: 587
SMTP_PORT=587

# TLS/SSL mode.
# Values: tls (STARTTLS on port 587) | ssl (implicit TLS on port 465) | (empty for no encryption)
SMTP_ENCRYPTION=tls

# SMTP credentials. Leave empty if your server allows unauthenticated relay.
SMTP_USER=
SMTP_PASSWORD=

# From address shown as the notification sender.
# Use a real deliverable address to avoid spam filtering.
SENDER_EMAIL=noreply@example.com

# Fallback admin e-mail address used in system notifications.
ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# LDAP / Active Directory integration (optional)
# -----------------------------------------------------------------------------
# When enabled, Ansilume can authenticate users against an LDAP/AD directory
# in addition to local accounts. LDAP users are auto-provisioned on first
# successful bind, cannot change their password through Ansilume, and are
# revoked locally if they are disabled or removed from the directory.
# See docs/ldap.md for full setup guidance and example role mappings.

# Master switch. Must be true to enable any LDAP code path.
# Values: true | false
# Default: false
LDAP_ENABLED=false

# Directory server hostname or IP.
#LDAP_HOST=dc01.example.com

# Directory port. 389 for plain/STARTTLS, 636 for LDAPS.
# Default: 389
#LDAP_PORT=389

# Transport encryption.
# none     — plaintext 389 (do NOT use in production)
# starttls — upgrade plain 389 connection to TLS (recommended for AD)
# ldaps    — implicit TLS on 636
# Default: none
#LDAP_ENCRYPTION=starttls

# Verify the directory server certificate. Production must keep this true.
# Default: true
#LDAP_VERIFY_PEER=true

# Network timeout for the initial bind in seconds.
# Default: 5
#LDAP_TIMEOUT=5

# Search base for user and group lookups.
#LDAP_BASE_DN=DC=example,DC=com

# Read-only service account used to look up users before binding as them.
# CHANGE-ME — create a dedicated account in the directory.
#LDAP_BIND_DN=CN=ansilume-svc,OU=Service Accounts,DC=example,DC=com
#LDAP_BIND_PASSWORD=CHANGE-ME

# LDAP filter to locate the user from the submitted username. %s is replaced
# with the escaped username.
#   AD:       (&(objectClass=user)(sAMAccountName=%s))
#   OpenLDAP: (&(objectClass=inetOrgPerson)(uid=%s))
# Default: (&(objectClass=user)(sAMAccountName=%s))
#LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName=%s))

# Attribute mapping. Defaults target Active Directory.
#LDAP_ATTR_USERNAME=sAMAccountName
#LDAP_ATTR_EMAIL=mail
#LDAP_ATTR_DISPLAY_NAME=displayName
# Stable identifier — objectGUID (AD) or entryUUID (OpenLDAP). Persisted to
# user.ldap_uid and survives directory renames.
#LDAP_ATTR_UID=objectGUID

# Group membership lookup. %s = user DN.
#   AD:       (&(objectClass=group)(member=%s))
#   OpenLDAP: (&(objectClass=posixGroup)(member=%s))
#LDAP_GROUP_FILTER=(&(objectClass=group)(member=%s))
#LDAP_GROUP_NAME_ATTR=cn

# Role mapping — JSON object mapping directory group names to Ansilume roles.
# Example: {"AnsilumeAdmins":"admin","AnsilumeOps":"operator","AnsilumeViewers":"viewer"}
# Default: {} (no automatic mapping; users get LDAP_DEFAULT_ROLE if set)
#LDAP_ROLE_MAPPING={}

# Fallback role when no group mapping matches.
# Empty = no role assigned; the user can log in but has no permissions
# until granted explicitly. For most setups, viewer is a safe default.
#LDAP_DEFAULT_ROLE=viewer

# Auto-create a local user record on first successful LDAP bind. Set to
# false to require admin pre-provisioning of LDAP user accounts.
# Default: true
#LDAP_AUTO_PROVISION=true

# -----------------------------------------------------------------------------
# Audit log — SIEM integration (optional)
# -----------------------------------------------------------------------------

# Forward audit events to syslog. Compatible with Promtail/Loki, Splunk syslog
# input, rsyslog, and most SIEM collectors. All security-relevant actions
# (logins, credential changes, job launches, permission changes) are forwarded.
# Values: true | false
# Default: false
AUDIT_SYSLOG_ENABLED=false

# syslog ident string prepended to each audit message.
# Default: ansilume
AUDIT_SYSLOG_IDENT=ansilume

# syslog facility used for audit messages.
# Common values: LOG_LOCAL0 … LOG_LOCAL7, LOG_DAEMON, LOG_USER
# Default: LOG_LOCAL0
AUDIT_SYSLOG_FACILITY=LOG_LOCAL0
